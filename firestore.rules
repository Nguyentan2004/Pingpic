rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if the user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Check if two users are accepted friends
    // Supports both friendships root collection and users/friends subcollection structures
    function areFriends(uid1, uid2) {
      return uid1 != null && uid2 != null && (
        // 1. users/{userId}/friends/{friendId} subcollection structure (requested)
        exists(/databases/$(database)/documents/users/$(uid1)/friends/$(uid2)) ||
        exists(/databases/$(database)/documents/users/$(uid2)/friends/$(uid1)) ||
        // 2. friendships root collection structure (current database schema)
        (exists(/databases/$(database)/documents/friendships/$(uid1 + '_' + uid2)) && 
         get(/databases/$(database)/documents/friendships/$(uid1 + '_' + uid2)).data.status == 'accepted') ||
        (exists(/databases/$(database)/documents/friendships/$(uid2 + '_' + uid1)) && 
         get(/databases/$(database)/documents/friendships/$(uid2 + '_' + uid1)).data.status == 'accepted')
      );
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Owner and accepted friends can read the full user document (including private fields)
      allow read: if isOwner(userId) || areFriends(userId, request.auth.uid);
      
      // Unauthenticated and authenticated users can perform single lookup (get) or search (list)
      // Note: Registration/login queries require this to verify usernames/emails before login
      allow get: if true;
      allow list: if request.query.limit <= 20;

      // Only the user themselves can create or update their own profile
      allow create, update: if isOwner(userId);
      // No one can delete user profiles from client
      allow delete: if false;

      // Subcollection for friends (optional requested structure support)
      match /friends/{friendId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
    }

    // --- FRIENDSHIPS COLLECTION ---
    match /friendships/{friendshipId} {
      // Users can view friendships they are a part of, or any accepted friendships
      allow read: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        resource.data.status == 'accepted'
      );
      // Anyone logged in can send a friend request, but sender must be themselves
      allow create: if isAuthenticated() && 
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.status == 'pending';
      // Only participants can update (accept request) or delete (unfriend/reject request)
      allow update, delete: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
    }

    // --- MOMENTS (PHOTOS) COLLECTION ---
    match /moments/{momentId} {
      // A moment can only be viewed by its owner OR an accepted friend of the owner
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        areFriends(resource.data.userId, request.auth.uid)
      );
      // Owner can upload moments, but must set userId to their own UID
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // Only the owner can delete their moments
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      // A moment can only be updated by its owner OR an accepted friend of the owner (to support likes/reactions)
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        areFriends(resource.data.userId, request.auth.uid)
      );
    }

    // --- MOMENT COMMENTS COLLECTION ---
    match /moments/{momentId}/comments/{commentId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid &&
        request.auth.uid in request.resource.data.participants &&
        (
          request.auth.uid == get(/databases/$(database)/documents/moments/$(momentId)).data.userId ||
          areFriends(get(/databases/$(database)/documents/moments/$(momentId)).data.userId, request.auth.uid)
        );
      allow delete: if isAuthenticated() &&
        resource.data.senderId == request.auth.uid;
    }

    // --- NOTIFICATIONS QUEUE COLLECTION ---
    match /notifications_queue/{queueId} {
      // Users can queue a notification, but must set senderId to their own UID
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.status == 'pending';
      // Read/Write access is denied to clients. Only Cloud Functions can process.
      allow read, update, delete: if false;
    }

    // --- NOTIFICATIONS COLLECTION ---
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.receiverId == request.auth.uid
      );
      allow update, delete: if isAuthenticated() && 
        resource.data.receiverId == request.auth.uid;
      // Any authenticated user can create a notification (e.g. sending a friend request)
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid;
    }
  }
}
